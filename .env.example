# Copy to `.env` for local development (`app.config.js` loads it via dotenv).

# --- Core (vendor-neutral defaults) ---
# `none` = skip login screens (default). `required` = show placeholder auth at app/(auth)/login.
EXPO_PUBLIC_AUTH_MODE=none

# Supabase (required when EXPO_PUBLIC_AUTH_MODE=required for OAuth). Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# `none` = no subscription gating / no paywall (default). `revenuecat` = enable RevenueCat + paywall gate.
EXPO_PUBLIC_SUBSCRIPTION_MODE=none

# --- Optional: RevenueCat (only when EXPO_PUBLIC_SUBSCRIPTION_MODE=revenuecat) ---
# Public API keys from RevenueCat → Project settings → API keys → App-specific / Public API key.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
